set terminal svg
set terminal svg background "white"
set output "Harm.svg"
set key top right
set xlabel "t"
set ylabel "y"
set tics out
set grid
set title "Harmonnic oscillator with friction"
plot "harm.txt" using 1:2 with lines linecolor "black" title "theta(t)", \
"harm.txt" using 1:3 with lines linecolor "red" title "omega(t)"

